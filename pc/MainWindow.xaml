<Window x:Class="WpfApp11.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="录入终端"
        Width="1640"
        Height="980"
        MinWidth="1500"
        MinHeight="900"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#2563EB" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="#E2E8F0" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="SectionGroupBoxStyle" TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Padding" Value="0" />
        </Style>
    </Window.Resources>

    <DockPanel Background="#F3F6F9">
        <Border DockPanel.Dock="Top" Background="#1E3A8A" Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="SmartOrder 录入终端" Foreground="White" FontWeight="Bold" FontSize="22" />
                    <Border Width="1" Height="18" Margin="16,0" Background="#60A5FA" />
                    <TextBlock Text="按 1.解析  2.审核  3.上传 的顺序完成当前批次" Foreground="#DBEAFE" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="当前账号" Foreground="#DBEAFE" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <ComboBox x:Name="CmbOperatorAccounts"
                              Width="220"
                              Height="30"
                              Margin="0,0,10,0"
                              IsEnabled="False"
                              SelectionChanged="CmbOperatorAccounts_SelectionChanged"
                              DisplayMemberPath="DisplayName" />
                    <TextBlock Text="业务群" Foreground="#DBEAFE" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <ComboBox x:Name="CmbBusinessGroups"
                              Width="180"
                              Height="30"
                              Margin="0,0,10,0"
                              SelectionChanged="CmbBusinessGroups_SelectionChanged"
                              DisplayMemberPath="Name" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl x:Name="MainTabs" Margin="14">
            <TabItem Header="录入工作台">
                <Grid Margin="0,6,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Style="{StaticResource CardBorderStyle}"
                            Margin="0,0,0,8"
                            Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="步骤 1 · 订单文本与基础数据" FontWeight="Bold" Foreground="#0F172A" />
                                <TextBlock Text="先粘贴订单文本再解析；商品表有变动时，也从这里导入。"
                                           Margin="0,2,0,8"
                                           FontSize="12"
                                           Foreground="#64748B"
                                           TextWrapping="Wrap" />
                                <WrapPanel ItemHeight="40" Margin="0,0,0,2">
                                    <!--<Button x:Name="BtnLoadSample" Content="加载示例" Width="100" Style="{StaticResource SecondaryActionButtonStyle}" Click="BtnLoadSample_Click" />-->
                                    <Button x:Name="BtnParse" Content="解析文本" Width="110" Style="{StaticResource PrimaryActionButtonStyle}" Click="BtnParse_Click" />
                                    <Button x:Name="BtnSaveParseRecord" Content="清空文本源" Width="130" Style="{StaticResource SecondaryActionButtonStyle}" Click="BtnSaveParseRecord_Click" />
                                    <Button x:Name="BtnImportCatalog" Content="导入商品列表" Width="120" Style="{StaticResource SecondaryActionButtonStyle}" Click="BtnImportCatalog_Click" />
                                </WrapPanel>
                                <WrapPanel ItemHeight="40" Width="650">
                                    <Grid Width="250" Height="30" Margin="0,0,6,6">
                                        <TextBox x:Name="TxtSearchKeyword"
                                                 Padding="8,0"
                                                 VerticalContentAlignment="Center"
                                                 TextChanged="TxtSearchKeyword_TextChanged"
                                                 KeyDown="TxtSearchKeyword_KeyDown" />
                                        <TextBlock Text="查询内容"
                                                   Margin="10,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="#94A3B8"
                                                   IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=TxtSearchKeyword}" Value="">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Text, ElementName=TxtSearchKeyword}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsKeyboardFocused, ElementName=TxtSearchKeyword}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <Button x:Name="BtnSearch"
                                            Content="查询文本源"
                                            Width="110"
                                            Style="{StaticResource PrimaryActionButtonStyle}"
                                            Click="BtnSearch_Click" />
                                    <Button x:Name="BtnSearchPrev"
                                            Content="上一个"
                                            Width="80"
                                            Style="{StaticResource SecondaryActionButtonStyle}"
                                            Click="BtnSearchPrev_Click" />
                                    <Button x:Name="BtnSearchNext"
                                            Content="下一个"
                                            Width="80"
                                            Style="{StaticResource SecondaryActionButtonStyle}"
                                            Click="BtnSearchNext_Click" />
                                </WrapPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <TextBlock Text="步骤 2 · 校验与人工修正" FontWeight="Bold" Foreground="#0F172A" />
                                <TextBlock Text="从订单队列切换订单，在右侧补齐收件信息和商品后再校验。"
                                           Margin="0,2,0,8"
                                           FontSize="12"
                                           Foreground="#64748B"
                                           TextWrapping="Wrap" />
                                <WrapPanel ItemHeight="40">
                                    <Button x:Name="BtnValidateCurrent" Content="校验当前订单" Width="130" Style="{StaticResource PrimaryActionButtonStyle}" Click="BtnValidateCurrent_Click" />
                                    <Button x:Name="BtnSkipCurrent" Content="跳过当前订单" Width="130" Style="{StaticResource SecondaryActionButtonStyle}" Click="BtnSkipCurrent_Click" />
                                </WrapPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="步骤 3 · 上传与批量处理" FontWeight="Bold" Foreground="#0F172A" />
                                <TextBlock Text="单条确认无误后可立即上传，也可以顺序批量上传当前待审订单。"
                                           Margin="0,2,0,8"
                                           FontSize="12"
                                           Foreground="#64748B"
                                           TextWrapping="Wrap" />
                                <WrapPanel ItemHeight="40">
                                    <Button x:Name="BtnSubmitCurrent" Content="上传当前订单" Width="130" Style="{StaticResource PrimaryActionButtonStyle}" Click="BtnSubmitCurrent_Click" />
                                    <Button x:Name="BtnSubmitAll" Content="批量上传待审订单" Width="160" Style="{StaticResource SecondaryActionButtonStyle}" Click="BtnSubmitAll_Click" />
                                </WrapPanel>
                                <TextBlock x:Name="TxtStatus"
                                           Margin="0,4,0,0"
                                           FontSize="12"
                                           Foreground="#334155"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.05*" />
                            <ColumnDefinition Width="1.95*" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="1.05*" />
                                <RowDefinition Height="0.95*" />
                            </Grid.RowDefinitions>

                            <GroupBox Grid.Row="0" Header="订单文本源" Style="{StaticResource SectionGroupBoxStyle}">
                                <DockPanel Margin="10">
                                    <TextBlock DockPanel.Dock="Top"
                                               Text="支持一次粘贴多段订单文本，解析后会自动拆成多条订单草稿。"
                                               Margin="0,0,0,8"
                                               Foreground="#64748B"
                                               TextWrapping="Wrap" />
                                    <TextBox x:Name="TxtInput"
                                             AcceptsReturn="True"
                                             AcceptsTab="True"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             TextChanged="TxtInput_TextChanged"
                                             TextWrapping="Wrap"
                                             FontFamily="Consolas"
                                             FontSize="14" />
                                </DockPanel>
                            </GroupBox>

                            <GroupBox Grid.Row="1" Header="订单队列" Style="{StaticResource SectionGroupBoxStyle}">
                                <DockPanel Margin="10">
                                    <TextBlock DockPanel.Dock="Top"
                                               Text="按顺序处理草稿。上传成功或跳过后，系统会自动切换到下一条。"
                                               Margin="0,0,0,8"
                                               Foreground="#64748B"
                                               TextWrapping="Wrap" />
                                    <DataGrid x:Name="GridDraftOrders"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              CanUserResizeRows="False"
                                              IsReadOnly="True"
                                              SelectionMode="Single"
                                              SelectionUnit="FullRow"
                                              SelectionChanged="GridDraftOrders_SelectionChanged">
                                        <DataGrid.RowStyle>
                                            <Style TargetType="DataGridRow">
                                                <Setter Property="Background" Value="#FEE2E2" />
                                                <Setter Property="Foreground" Value="#7F1D1D" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAllItemsExact}" Value="True">
                                                        <Setter Property="Background" Value="#DCFCE7" />
                                                        <Setter Property="Foreground" Value="#166534" />
                                                    </DataTrigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Foreground" Value="#0F172A" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.RowStyle>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="订单号" Binding="{Binding OrderNumber}" Width="165" />
                                            <DataGridTextColumn Header="收件人" Binding="{Binding ReceiverName}" Width="90" />
                                            <DataGridTextColumn Header="手机号" Binding="{Binding ReceiverMobile}" Width="96" />
                                            <DataGridTextColumn Header="商品概要" Binding="{Binding GoodsSummary}" Width="*" />
                                            <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="74" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </GroupBox>
                        </Grid>

                        <GroupBox Grid.Column="1" Header="订单草稿编辑" Margin="0,0,0,8">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition></ColumnDefinition>
                                    <ColumnDefinition Width="200"></ColumnDefinition>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                     Text="附加信息"
                     Margin="0,0,0,6"
                     Foreground="#334155"
                     FontWeight="SemiBold" />
                                    <CheckBox x:Name="ChkDraftHasGift"
                    Grid.Row="1"
                    Content="是否有赠品"
                    VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="3"
                     Text="备注"
                     Margin="0,0,0,6"
                     Foreground="#64748B" />
                                    <TextBox x:Name="TxtDraftRemark"
                   Grid.Row="4"
                   Height="112"
                   Padding="10,0"
                   AcceptsReturn="True"
 TextWrapping="Wrap"
 VerticalContentAlignment="Top"
 VerticalScrollBarVisibility="Auto"
                   ToolTip="备注（选填）" />
                                </Grid>

                                <Border Grid.Row="0"
                                        Background="White"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12"
                                        Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="10" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.15*" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Grid Grid.Column="0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0"
                                                           Text="收件人 *"
                                                           Margin="0,0,0,6"
                                                           Foreground="#334155"
                                                           FontWeight="SemiBold" />
                                                <TextBox x:Name="TxtDraftReceiverName"
                                                         Grid.Row="1"
                                                         Height="32"
                                                         Padding="10,0"
                                                         VerticalContentAlignment="Center" />
                                            </Grid>

                                            <Grid Grid.Column="2">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0"
                                                           Text="收件手机号 *"
                                                           Margin="0,0,0,6"
                                                           Foreground="#334155"
                                                           FontWeight="SemiBold" />
                                                <TextBox x:Name="TxtDraftReceiverMobile"
                                                         Grid.Row="1"
                                                         Height="32"
                                                         Padding="10,0"
                                                         VerticalContentAlignment="Center" />
                                            </Grid>
                                        </Grid>

                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.2*" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="240" />
                                            </Grid.ColumnDefinitions>

                                            <Grid Grid.Column="0" Grid.ColumnSpan="3">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0"
                                                           Text="详细地址 *"
                                                           Margin="0,0,0,6"
                                                           Foreground="#334155"
                                                           FontWeight="SemiBold" />
                                                <TextBox x:Name="TxtDraftReceiverAddress"
                                                         Grid.Row="1"
                                                         MinHeight="76"
                                                         Padding="10,8"
                                                         AcceptsReturn="True"
                                                         TextWrapping="Wrap"
                                                         VerticalContentAlignment="Top"
                                                         VerticalScrollBarVisibility="Auto" />
                                            </Grid>

                                      </Grid>
                                    </Grid>
                                </Border>

                                <DockPanel Grid.Row="1" Grid.ColumnSpan="2">
                                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="商品集合（必填：商品编码 / 数量）" FontWeight="Bold" VerticalAlignment="Center" />
                                            <Button x:Name="BtnAddItem" Content="+ 添加商品" Width="100" Height="28" Margin="12,0,8,0" Click="BtnAddItem_Click" />
                                            <Button x:Name="BtnRemoveItem" Content="删除选中商品" Width="110" Height="28" Click="BtnRemoveItem_Click" />
                                        </StackPanel>
                                        <TextBlock x:Name="TxtProductWorkflowSummary"
                                                   FontSize="12"
                                                   Foreground="#334155"
                                                   TextWrapping="Wrap" />
                                        <TextBlock x:Name="TxtProductWorkflowHint"
                                                   Margin="0,2,0,0"
                                                   FontSize="11"
                                                   Foreground="#64748B"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <DataGrid x:Name="GridDraftItems"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              Height="312"
                                              SelectionMode="Single"
                                              ScrollViewer.CanContentScroll="True"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                              VirtualizingPanel.ScrollUnit="Item"
                                              SelectionChanged="GridDraftItems_SelectionChanged"
                                              CellEditEnding="GridDraftItems_CellEditEnding">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="序号"
                                                                Binding="{Binding SequenceNumber}"
                                                                Width="60"
                                                                IsReadOnly="True" />
                                            <DataGridTemplateColumn Header="商品编码 *" Width="2.25*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Click="ProductCodeCellButton_Click"
                                                                Padding="0"
                                                                Background="Transparent"
                                                                BorderThickness="0"
                                                                HorizontalContentAlignment="Stretch"
                                                                ToolTip="{Binding MatchHint}">
                                                            <Border Padding="10"
                                                                    CornerRadius="10"
                                                                    BorderThickness="1">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="#F8FAFC" />
                                                                        <Setter Property="BorderBrush" Value="#CBD5E1" />
                                                                        <Style.Triggers>
                                                                            <MultiDataTrigger>
                                                                                <MultiDataTrigger.Conditions>
                                                                                    <Condition Binding="{Binding ProductMatchState}" Value="Exact" />
                                                                                    <Condition Binding="{Binding UseManualProductCodeStyle}" Value="False" />
                                                                                </MultiDataTrigger.Conditions>
                                                                                <Setter Property="Background" Value="#DCFCE7" />
                                                                                <Setter Property="BorderBrush" Value="#22C55E" />
                                                                            </MultiDataTrigger>
                                                                            <MultiDataTrigger>
                                                                                <MultiDataTrigger.Conditions>
                                                                                    <Condition Binding="{Binding ProductMatchState}" Value="Unmatched" />
                                                                                    <Condition Binding="{Binding UseManualProductCodeStyle}" Value="False" />
                                                                                </MultiDataTrigger.Conditions>
                                                                                <Setter Property="Background" Value="#FEE2E2" />
                                                                                <Setter Property="BorderBrush" Value="#EF4444" />
                                                                            </MultiDataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <StackPanel>
                                                                    <DockPanel>
                                                                        <TextBlock Text="{Binding ProductCodeDisplayText}"
                                                                                   VerticalAlignment="Center"
                                                                                   FontWeight="SemiBold">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Foreground" Value="#475569" />
                                                                                    <Style.Triggers>
                                                                                        <MultiDataTrigger>
                                                                                            <MultiDataTrigger.Conditions>
                                                                                                <Condition Binding="{Binding ProductMatchState}" Value="Exact" />
                                                                                                <Condition Binding="{Binding UseManualProductCodeStyle}" Value="False" />
                                                                                            </MultiDataTrigger.Conditions>
                                                                                            <Setter Property="Foreground" Value="#166534" />
                                                                                        </MultiDataTrigger>
                                                                                        <MultiDataTrigger>
                                                                                            <MultiDataTrigger.Conditions>
                                                                                                <Condition Binding="{Binding ProductMatchState}" Value="Unmatched" />
                                                                                                <Condition Binding="{Binding UseManualProductCodeStyle}" Value="False" />
                                                                                            </MultiDataTrigger.Conditions>
                                                                                            <Setter Property="Foreground" Value="#B91C1C" />
                                                                                        </MultiDataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                        <Border DockPanel.Dock="Right"
                                                                                CornerRadius="999"
                                                                                Padding="8,2"
                                                                                Margin="8,0,0,0">
                                                                            <Border.Style>
                                                                                <Style TargetType="Border">
                                                                                    <Setter Property="Background" Value="#E2E8F0" />
                                                                                    <Style.Triggers>
                                                                                        <MultiDataTrigger>
                                                                                            <MultiDataTrigger.Conditions>
                                                                                                <Condition Binding="{Binding ProductMatchState}" Value="Exact" />
                                                                                                <Condition Binding="{Binding UseManualProductCodeStyle}" Value="False" />
                                                                                            </MultiDataTrigger.Conditions>
                                                                                            <Setter Property="Background" Value="#BBF7D0" />
                                                                                        </MultiDataTrigger>
                                                                                        <MultiDataTrigger>
                                                                                            <MultiDataTrigger.Conditions>
                                                                                                <Condition Binding="{Binding ProductMatchState}" Value="Unmatched" />
                                                                                                <Condition Binding="{Binding UseManualProductCodeStyle}" Value="False" />
                                                                                            </MultiDataTrigger.Conditions>
                                                                                            <Setter Property="Background" Value="#FECACA" />
                                                                                        </MultiDataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>
                                                                            <TextBlock Text="{Binding ProductMatchStatusText}" FontSize="11" FontWeight="SemiBold">
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="TextBlock">
                                                                                        <Setter Property="Foreground" Value="#475569" />
                                                                                        <Style.Triggers>
                                                                                            <MultiDataTrigger>
                                                                                                <MultiDataTrigger.Conditions>
                                                                                                    <Condition Binding="{Binding ProductMatchState}" Value="Exact" />
                                                                                                    <Condition Binding="{Binding UseManualProductCodeStyle}" Value="False" />
                                                                                                </MultiDataTrigger.Conditions>
                                                                                                <Setter Property="Foreground" Value="#15803D" />
                                                                                            </MultiDataTrigger>
                                                                                            <MultiDataTrigger>
                                                                                                <MultiDataTrigger.Conditions>
                                                                                                    <Condition Binding="{Binding ProductMatchState}" Value="Unmatched" />
                                                                                                    <Condition Binding="{Binding UseManualProductCodeStyle}" Value="False" />
                                                                                                </MultiDataTrigger.Conditions>
                                                                                                <Setter Property="Foreground" Value="#B91C1C" />
                                                                                            </MultiDataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                        </Border>
                                                                    </DockPanel>
                                                                    <TextBlock Text="{Binding ProductCodeSearchSummary}"
                                                                               Margin="0,4,0,0"
                                                                               FontSize="11"
                                                                               Foreground="#64748B"
                                                                               TextWrapping="Wrap" />
                                                                    <TextBlock Text="{Binding ProductWorkflowSummary}"
                                                                               Margin="0,4,0,0"
                                                                               FontSize="11"
                                                                               TextWrapping="Wrap">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Foreground" Value="#475569" />
                                                                                <Style.Triggers>
                                                                                    <MultiDataTrigger>
                                                                                        <MultiDataTrigger.Conditions>
                                                                                            <Condition Binding="{Binding ProductMatchState}" Value="Exact" />
                                                                                            <Condition Binding="{Binding UseManualProductCodeStyle}" Value="False" />
                                                                                        </MultiDataTrigger.Conditions>
                                                                                        <Setter Property="Foreground" Value="#166534" />
                                                                                    </MultiDataTrigger>
                                                                                    <MultiDataTrigger>
                                                                                        <MultiDataTrigger.Conditions>
                                                                                            <Condition Binding="{Binding ProductMatchState}" Value="Unmatched" />
                                                                                            <Condition Binding="{Binding UseManualProductCodeStyle}" Value="False" />
                                                                                        </MultiDataTrigger.Conditions>
                                                                                        <Setter Property="Foreground" Value="#B91C1C" />
                                                                                    </MultiDataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                    <TextBlock Text="点击选择商品编码，确认后才会关闭选择窗口"
                                                                               Margin="0,4,0,0"
                                                                               FontSize="10"
                                                                               Foreground="#94A3B8" />
                                                                </StackPanel>
                                                            </Border>
                                                        </Button>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="数量 *" Binding="{Binding QuantityText, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </Grid>
                        </GroupBox>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="处理信息">
                <Grid Margin="0,6,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="1.5*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,8,0" Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="步骤 1 · 订单文本" Foreground="#475569" FontWeight="SemiBold" />
                                <TextBlock x:Name="TxtParseSummary"
                                           Margin="0,6,0,0"
                                           FontSize="13"
                                           Foreground="#0F172A"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Margin="0,0,8,0" Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="步骤 2 · 草稿队列" Foreground="#475569" FontWeight="SemiBold" />
                                <TextBlock x:Name="TxtQueueSummary"
                                           Margin="0,6,0,0"
                                           FontSize="13"
                                           Foreground="#0F172A"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Margin="0,0,8,0" Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="当前订单" Foreground="#475569" FontWeight="SemiBold" />
                                <TextBlock x:Name="TxtCurrentDraftHeadline"
                                           Margin="0,6,0,0"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#0F172A"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="TxtCurrentDraftMeta"
                                           Margin="0,4,0,0"
                                           FontSize="12"
                                           Foreground="#64748B"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3" Style="{StaticResource CardBorderStyle}" Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="批次概览" Foreground="#475569" FontWeight="SemiBold" />
                                <TextBlock x:Name="TxtWorkbenchSummary"
                                           Margin="0,6,0,0"
                                           FontSize="13"
                                           Foreground="#0F172A"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="TxtFlowHint"
                                           Margin="0,4,0,0"
                                           FontSize="12"
                                           Foreground="#2563EB"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <GroupBox Grid.Row="1" Header="校验 / 上传响应 / 原始记录">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="1.3*" />
                                <ColumnDefinition Width="1.25*" />
                            </Grid.ColumnDefinitions>

                            <GroupBox Grid.Column="0" Header="校验结果">
                                <TextBox x:Name="TxtValidationOutput"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         TextWrapping="Wrap"
                                         FontFamily="Consolas" />
                            </GroupBox>

                            <GroupBox Grid.Column="1" Header="上传响应" Margin="10,0">
                                <TextBox x:Name="TxtUploadOutput"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         TextWrapping="Wrap"
                                         FontFamily="Consolas" />
                            </GroupBox>

                            <GroupBox Grid.Column="2" Header="当前订单原文">
                                <TextBox x:Name="TxtCurrentRawOrder"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         TextWrapping="Wrap"
                                         FontFamily="Consolas" />
                            </GroupBox>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>
            <TabItem Header="设置中心">
                <DockPanel Margin="0,6,0,0">
                    <Border DockPanel.Dock="Top"
                            Background="White"
                            CornerRadius="14"
                            Padding="12"
                            Margin="0,0,0,10"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1">
                        <WrapPanel>
                            <Button x:Name="BtnSaveSettings" Content="保存设置" Width="100" Height="34" Margin="0,0,8,8" Click="BtnSaveSettings_Click" />
                            <Button x:Name="BtnImportSettings" Content="导入设置" Width="100" Height="34" Margin="0,0,8,8" Click="BtnImportSettings_Click" />
                            <Button x:Name="BtnExportSettings" Content="导出设置" Width="100" Height="34" Margin="0,0,8,8" Click="BtnExportSettings_Click" />
                            <Button x:Name="BtnAddSettingsRow" Content="新增当前行" Width="120" Height="34" Margin="0,0,8,8" Click="BtnAddSettingsRow_Click" />
                            <Button x:Name="BtnRemoveSettingsRow" Content="删除当前行" Width="120" Height="34" Margin="0,0,8,8" Click="BtnRemoveSettingsRow_Click" />
                            <TextBlock x:Name="TxtSettingsStatus" Margin="10,8,0,0" Foreground="#334155" TextWrapping="Wrap" />
                        </WrapPanel>
                    </Border>

                    <TabControl x:Name="SettingsTabs">
                        <TabItem Header="周期列表">
                            <DataGrid x:Name="GridWearPeriods" AutoGenerateColumns="False" CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="标准周期" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="周期对照表">
                            <DataGrid x:Name="GridWearMappings" AutoGenerateColumns="False" CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="文本别名" Binding="{Binding Alias, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                    <DataGridComboBoxColumn x:Name="ColSettingsWearMapping"
                                                            Header="对应周期"
                                                            Width="200"
                                                            SelectedValueBinding="{Binding WearPeriod, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectedValuePath="Value"
                                                            DisplayMemberPath="Value" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="商品编码列表">
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="2*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="原始商品编码保持不变，设置页只按 周期 / 型号 聚合展示。点击“查看度数”后，在右侧查看该类下的全部商品编码。"
                                           Foreground="#475569"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8" />

                                <TextBlock x:Name="TxtProductCatalogDetailTitle"
                                           Grid.Column="2"
                                           Text="度数明细"
                                           Foreground="#0F172A"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8" />

                                <DataGrid x:Name="GridProductCatalog"
                                          Grid.Row="1"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          SelectionChanged="GridProductCatalog_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="周期"
                                                            Binding="{Binding WearPeriod}"
                                                            Width="140" />
                                        <DataGridTemplateColumn Header="型号"
                                                                Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Click="BtnShowProductCatalogDegrees_Click"
                                                            Padding="10,4"
                                                            HorizontalAlignment="Stretch"
                                                            HorizontalContentAlignment="Left"
                                                            Background="#F8FAFC"
                                                            BorderBrush="#CBD5E1"
                                                            BorderThickness="1">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding ModelName}"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#0F172A"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding DegreeSummary}"
                                                                       Margin="0,2,0,0"
                                                                       Foreground="#64748B"
                                                                       FontSize="12"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Button>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <DataGrid x:Name="GridProductCatalogDegrees"
                                          Grid.Row="1"
                                          Grid.Column="2"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="度数"
                                                            Binding="{Binding DegreeText}"
                                                            Width="100" />
                                        <DataGridTextColumn Header="商品编码"
                                                            Binding="{Binding ProductCode}"
                                                            Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>
                        <TabItem Header="编码对照表">
                            <DataGrid x:Name="GridProductMappings" AutoGenerateColumns="False" CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="文本别名" Binding="{Binding Alias, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                    <DataGridTextColumn Header="商品编码" Binding="{Binding ProductCode, UpdateSourceTrigger=PropertyChanged}" Width="180" />
                                    <DataGridTextColumn Header="备注" Binding="{Binding Note, UpdateSourceTrigger=PropertyChanged}" Width="220" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="账号 ERP 映射">
                            <DataGrid x:Name="GridUserAccounts" AutoGenerateColumns="False" CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="登录账号" Binding="{Binding LoginName, UpdateSourceTrigger=PropertyChanged}" Width="180" />
                                    <DataGridTextColumn Header="显示名" Binding="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" Width="180" />
                                    <DataGridTextColumn Header="ERPID" Binding="{Binding ErpId, UpdateSourceTrigger=PropertyChanged}" Width="180" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="接口配置">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <Grid Margin="20">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="主服务地址" Margin="0,0,0,6" />
                                    <TextBox x:Name="TxtMainApiBaseUrl" Grid.Row="1" Height="30" Margin="0,0,0,12" ToolTip="登录与主服务联动默认地址" />
                                    <TextBlock Grid.Row="2" Text="ERP 接口地址" Margin="0,0,0,6" />
                                    <TextBox x:Name="TxtUploadApiUrl" Grid.Row="3" Height="30" Margin="0,0,0,12" />
                                    <TextBlock Grid.Row="4" Text="AppKey / Secret" Margin="0,0,0,6" />
                                    <Grid Grid.Row="5" Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="TxtUploadAppKey" Grid.Column="0" Margin="0,0,8,0" Height="30" />
                                        <TextBox x:Name="TxtUploadSecret" Grid.Column="1" Height="30" />
                                    </Grid>
                                    <TextBlock Grid.Row="6" Text="店铺名称" Margin="0,0,0,6" />
                                    <TextBox x:Name="TxtUploadShopNick" Grid.Row="7" Height="30" Margin="0,0,0,12" ToolTip="官方接口里的 shop_nick，默认手工单" />
                                    <TextBlock Grid.Row="8" Text="扩展字段名（留空则不传）" Margin="0,0,0,6" />
                                    <Grid Grid.Row="9" Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="TxtOperatorFieldName" Grid.Column="0" Margin="0,0,8,0" Height="30" ToolTip="业务员 ERPID 字段名" />
                                        <TextBox x:Name="TxtGiftFieldName" Grid.Column="1" Margin="0,0,8,0" Height="30" ToolTip="赠品标记字段名" />
                                        <TextBox x:Name="TxtItemWearPeriodFieldName" Grid.Column="2" Height="30" ToolTip="商品周期字段名" />
                                    </Grid>
                                    <StackPanel Grid.Row="10" Orientation="Horizontal">
                                        <Button x:Name="BtnQueryTradeRecords"
                                                Content="查询订单记录"
                                                Width="160"
                                                Style="{StaticResource SecondaryActionButtonStyle}"
                                                Click="BtnQueryTradeRecords_Click" />

                                        <Button x:Name="BtnQueryGoodsCodes"
                                                Content="查询商品编码"
                                                Width="160"
                                                Style="{StaticResource SecondaryActionButtonStyle}"
                                                Click="BtnQueryGoodsCodes_Click" />
                                    </StackPanel>
                                    <TextBlock Grid.Row="11"
                                               Margin="0,12,0,8"
                                               Foreground="#64748B"
                                               TextWrapping="Wrap"
                                               Text="注意：该接口查不到淘系和拼多多订单，且收货人信息会脱敏或不返回；无需发货场景建议改查出库单接口。" />
                                    <TextBox x:Name="TxtTradeQueryResult"
                                             Grid.Row="12"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             TextWrapping="Wrap"
                                             IsReadOnly="True"
                                             MinHeight="220"
                                             Padding="10"
                                             FontFamily="Consolas"
                                             FontSize="12"
                                             Background="#F8FAFC"
                                             BorderBrush="#CBD5E1"
                                             BorderThickness="1" />
                                </Grid>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </DockPanel>
            </TabItem>

            <TabItem Header="训练语义" Visibility="Collapsed">
                <Grid Margin="0,6,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Style="{StaticResource CardBorderStyle}"
                            Margin="0,0,0,10"
                            Padding="14,12">
                        <StackPanel>
                            <TextBlock Text="训练输入 + 期望输出" FontWeight="Bold" FontSize="16" Foreground="#0F172A" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="#475569"
                                       TextWrapping="Wrap"
                                       Text="左侧贴原始订单文本，右侧写期望输出 JSON。点击“应用到语义”后，会把样本保存下来，并把 JSON 里的周期别名和商品别名写入当前语义设置。" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="#64748B"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Text='JSON 支持：{"wearPeriod":"半年抛","wearAliases":["半年抛","半抛"],"items":[{"productName":"次元梦境pro紫","aliases":["次元梦境pro紫0/0一副"],"wearPeriod":"半年抛","degree":"0","quantity":1}]}' />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <GroupBox Grid.Column="0" Header="训练输入" Margin="0,0,10,0">
                            <TextBox x:Name="TxtTrainingInput"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     FontFamily="Consolas"
                                     FontSize="13"
                                     Padding="10" />
                        </GroupBox>

                        <GroupBox Grid.Column="1" Header="结构化训练输出">
                            <Grid Margin="6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="150" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="190" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <DataGrid x:Name="GridTrainingOrders"
                                          Grid.Row="0"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          SelectionMode="Single"
                                          SelectionChanged="GridTrainingOrders_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="收件人"
                                                            Binding="{Binding ReceiverName, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="90" />
                                        <DataGridTextColumn Header="手机号"
                                                            Binding="{Binding ReceiverMobile, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="120" />
                                        <DataGridTextColumn Header="周期"
                                                            Binding="{Binding WearPeriod, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="90" />
                                        <DataGridTextColumn Header="周期别名"
                                                            Binding="{Binding WearAliasesText, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Grid Grid.Row="1" Margin="0,8,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="收件地址" Margin="0,0,0,4" Foreground="#475569" />
                                        <TextBox x:Name="TxtTrainingReceiverAddress"
                                                 Text="{Binding ElementName=GridTrainingOrders, Path=SelectedItem.ReceiverAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 MinHeight="62"
                                                 VerticalScrollBarVisibility="Auto" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="订单周期别名（逗号分隔）" Margin="0,0,0,4" Foreground="#475569" />
                                        <TextBox x:Name="TxtTrainingOrderAliases"
                                                 Text="{Binding ElementName=GridTrainingOrders, Path=SelectedItem.WearAliasesText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 MinHeight="62"
                                                 VerticalScrollBarVisibility="Auto" />
                                    </StackPanel>
                                </Grid>

                                <DataGrid x:Name="GridTrainingItems"
                                          Grid.Row="2"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="型号"
                                                            Binding="{Binding ProductName, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="*" />
                                        <DataGridTextColumn Header="周期"
                                                            Binding="{Binding WearPeriod, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="90" />
                                        <DataGridTextColumn Header="度数"
                                                            Binding="{Binding Degree, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="90" />
                                        <DataGridTextColumn Header="数量"
                                                            Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="70" />
                                        <DataGridTextColumn Header="商品别名"
                                                            Binding="{Binding AliasesText, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="220" />
                                        <DataGridTextColumn Header="周期别名"
                                                            Binding="{Binding WearAliasesText, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="180" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock Grid.Row="3"
                                           Margin="0,8,0,6"
                                           Foreground="#64748B"
                                           TextWrapping="Wrap"
                                           Text="右侧改为结构化字段编辑；保存训练样本和应用到语义时，仍会自动转换成同一份训练语义结果。" />

                                <Border Grid.Row="4"
                                        Background="#F8FAFC"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10">
                                    <TextBlock x:Name="TxtTrainingStructuredHint"
                                               Foreground="#475569"
                                               TextWrapping="Wrap"
                                               Text="先点“生成当前解析结果”，再在这里直接改收件信息、周期、别名、商品和度数。" />
                                </Border>
                            </Grid>
                        </GroupBox>
                    </Grid>

                    <Border Grid.Row="2"
                            Style="{StaticResource CardBorderStyle}"
                            Margin="0,10,0,0"
                            Padding="12,10">
                        <DockPanel>
                            <TextBlock x:Name="TxtTrainingStatus"
                                       VerticalAlignment="Center"
                                       Foreground="#334155"
                                       TextWrapping="Wrap"
                                       Text="把训练输入和结构化字段整理好后，可以先生成当前解析结果，再保存样本或应用到语义。" />
                            <WrapPanel DockPanel.Dock="Right">
                                <Button x:Name="BtnTrainingUseCurrent"
                                        Content="带入当前文本"
                                        Width="110"
                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                        Click="BtnTrainingUseCurrent_Click" />
                                <Button x:Name="BtnTrainingGenerate"
                                        Content="生成当前解析结果"
                                        Width="130"
                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                        Click="BtnTrainingGenerate_Click" />
                                <Button x:Name="BtnTrainingSaveSample"
                                        Content="保存训练样本"
                                        Width="120"
                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                        Click="BtnTrainingSaveSample_Click" />
                                <Button x:Name="BtnTrainingApply"
                                        Content="应用到语义"
                                        Width="120"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Click="BtnTrainingApply_Click" />
                            </WrapPanel>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="历史记录">
                <Grid Margin="0,6,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="250" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Style="{StaticResource CardBorderStyle}"
                            Padding="12"
                            Margin="0,0,0,10">
                        <DockPanel LastChildFill="True">
                            <WrapPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                <StackPanel Width="180" Margin="0,0,10,0">
                                    <TextBlock Text="订单号（完全匹配）" Margin="0,0,0,4" Foreground="#475569" />
                                    <TextBox x:Name="TxtHistoryOrderNumberFilter"
                                             Height="32"
                                             Padding="10,0"
                                             VerticalContentAlignment="Center"
                                             KeyDown="HistoryFilterInput_KeyDown" />
                                </StackPanel>
                                <StackPanel Width="150" Margin="0,0,10,0">
                                    <TextBlock Text="收件人" Margin="0,0,0,4" Foreground="#475569" />
                                    <TextBox x:Name="TxtHistoryReceiverFilter"
                                             Height="32"
                                             Padding="10,0"
                                             VerticalContentAlignment="Center"
                                             KeyDown="HistoryFilterInput_KeyDown" />
                                </StackPanel>
                                <StackPanel Width="140" Margin="0,0,10,0">
                                    <TextBlock Text="开始时间" Margin="0,0,0,4" Foreground="#475569" />
                                    <DatePicker x:Name="DpHistoryStartDate"
                                                Height="32" />
                                </StackPanel>
                                <StackPanel Width="140" Margin="0,0,10,0">
                                    <TextBlock Text="结束时间" Margin="0,0,0,4" Foreground="#475569" />
                                    <DatePicker x:Name="DpHistoryEndDate"
                                                Height="32" />
                                </StackPanel>
                            </WrapPanel>
                            <WrapPanel DockPanel.Dock="Right" VerticalAlignment="Bottom">
                                <Button x:Name="BtnApplyHistoryFilter"
                                        Content="查询"
                                        Width="88"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Click="BtnApplyHistoryFilter_Click" />
                                <Button x:Name="BtnResetHistoryFilter"
                                        Content="重置"
                                        Width="88"
                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                        Click="BtnResetHistoryFilter_Click" />
                            </WrapPanel>
                        </DockPanel>
                    </Border>

                    <DataGrid x:Name="GridHistory"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              SelectionChanged="GridHistory_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="操作" Width="92">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="取消订单"
                                                Width="76"
                                                Padding="0"
                                                Style="{StaticResource SecondaryActionButtonStyle}"
                                                Click="BtnCancelHistoryOrder_Click" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="订单号" Binding="{Binding OrderNumber}" Width="130" />
                            <DataGridTextColumn Header="时间" Binding="{Binding Timestamp}" Width="160" />
                            <DataGridTextColumn Header="动作" Binding="{Binding ActionType}" Width="100" />
                            <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="100" />
                            <DataGridTextColumn Header="收件人" Binding="{Binding ReceiverName}" Width="100" />
                            <DataGridTextColumn Header="手机号" Binding="{Binding ReceiverMobile}" Width="110" />
                            <DataGridTextColumn Header="商品概要" Binding="{Binding GoodsSummary}" Width="*" />
                            <DataGridTextColumn Header="业务员" Binding="{Binding OperatorLoginName}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="1.15*" />
                            <ColumnDefinition Width="1.3*" />
                        </Grid.ColumnDefinitions>
                        <GroupBox Grid.Column="0" Header="原始文本">
                            <TextBox x:Name="TxtHistoryRaw"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     FontFamily="Consolas" />
                        </GroupBox>
                        <GroupBox Grid.Column="1" Header="录入快照" Margin="10,0,0,0">
                            <TextBox x:Name="TxtHistorySnapshot"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     FontFamily="Consolas" />
                        </GroupBox>
                        <GroupBox Grid.Column="2" Header="接口响应 / 处理说明" Margin="10,0,0,0">
                            <TextBox x:Name="TxtHistoryResponse"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     FontFamily="Consolas" />
                        </GroupBox>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
