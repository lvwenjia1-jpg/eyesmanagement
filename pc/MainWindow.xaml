<Window x:Class="WpfApp11.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="智能订单录入系统"
        Width="1680"
        Height="980"
        MinWidth="1500"
        MinHeight="900"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#2563EB" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="#E2E8F0" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="SectionGroupBoxStyle" TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Padding" Value="0" />
        </Style>
    </Window.Resources>

    <DockPanel Background="#F3F6F9">
        <Border DockPanel.Dock="Top" Background="#1E3A8A" Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="SmartOrder 录入终端" Foreground="White" FontWeight="Bold" FontSize="22" />
                    <Border Width="1" Height="18" Margin="16,0" Background="#60A5FA" />
                    <TextBlock Text="按 1. 解析  2. 审核  3. 上传 的顺序完成当前批次" Foreground="#DBEAFE" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="当前账号" Foreground="#DBEAFE" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <ComboBox x:Name="CmbOperatorAccounts"
                              Width="220"
                              Height="30"
                              Margin="0,0,10,0"
                              SelectionChanged="CmbOperatorAccounts_SelectionChanged"
                              DisplayMemberPath="DisplayName" />
                    <Button Content="打开目录"
                            Width="90"
                            Height="30"
                            Click="BtnOpenFolder_Click"
                            Background="#DBEAFE"
                            Foreground="#1E3A8A"
                            BorderBrush="#BFDBFE" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl x:Name="MainTabs" Margin="14">
            <TabItem Header="录入工作台">
                <Grid Margin="0,6,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="138" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="1.5*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,8,0" Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="步骤 1 · 订单文本" Foreground="#475569" FontWeight="SemiBold" />
                                <TextBlock x:Name="TxtParseSummary"
                                           Margin="0,6,0,0"
                                           FontSize="13"
                                           Foreground="#0F172A"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Margin="0,0,8,0" Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="步骤 2 · 草稿队列" Foreground="#475569" FontWeight="SemiBold" />
                                <TextBlock x:Name="TxtQueueSummary"
                                           Margin="0,6,0,0"
                                           FontSize="13"
                                           Foreground="#0F172A"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Margin="0,0,8,0" Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="当前订单" Foreground="#475569" FontWeight="SemiBold" />
                                <TextBlock x:Name="TxtCurrentDraftHeadline"
                                           Margin="0,6,0,0"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#0F172A"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="TxtCurrentDraftMeta"
                                           Margin="0,4,0,0"
                                           FontSize="12"
                                           Foreground="#64748B"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="3" Style="{StaticResource CardBorderStyle}" Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="批次概览" Foreground="#475569" FontWeight="SemiBold" />
                                <TextBlock x:Name="TxtWorkbenchSummary"
                                           Margin="0,6,0,0"
                                           FontSize="13"
                                           Foreground="#0F172A"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="TxtFlowHint"
                                           Margin="0,4,0,0"
                                           FontSize="12"
                                           Foreground="#2563EB"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="1"
                            Style="{StaticResource CardBorderStyle}"
                            Margin="0,0,0,8"
                            Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="步骤 1 · 准备文本与基础数据" FontWeight="Bold" Foreground="#0F172A" />
                                <TextBlock Text="先加载示例或粘贴订单文本，再解析；商品表需要变化时可在这里导入。"
                                           Margin="0,2,0,8"
                                           FontSize="12"
                                           Foreground="#64748B"
                                           TextWrapping="Wrap" />
                                <WrapPanel ItemHeight="30">
                                    <Button x:Name="BtnLoadSample" Content="加载示例" Width="100" Style="{StaticResource SecondaryActionButtonStyle}" Click="BtnLoadSample_Click" />
                                    <Button x:Name="BtnParse" Content="解析文本" Width="110" Style="{StaticResource PrimaryActionButtonStyle}" Click="BtnParse_Click" />
                                    <Button x:Name="BtnSaveParseRecord" Content="保存解析记录" Width="130" Style="{StaticResource SecondaryActionButtonStyle}" Click="BtnSaveParseRecord_Click" />
                                    <Button x:Name="BtnImportCatalog" Content="导入商品列表" Width="120" Style="{StaticResource SecondaryActionButtonStyle}" Click="BtnImportCatalog_Click" />
                                </WrapPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <TextBlock Text="步骤 2 · 校验与人工修正" FontWeight="Bold" Foreground="#0F172A" />
                                <TextBlock Text="从中间队列切换订单，在右侧补全收件信息与商品，再执行校验。"
                                           Margin="0,2,0,8"
                                           FontSize="12"
                                           Foreground="#64748B"
                                           TextWrapping="Wrap" />
                                <WrapPanel ItemHeight="30">
                                    <Button x:Name="BtnValidateCurrent" Content="校验当前订单" Width="130" Style="{StaticResource PrimaryActionButtonStyle}" Click="BtnValidateCurrent_Click" />
                                    <Button x:Name="BtnSkipCurrent" Content="跳过当前订单" Width="130" Style="{StaticResource SecondaryActionButtonStyle}" Click="BtnSkipCurrent_Click" />
                                </WrapPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="步骤 3 · 上传与批量处理" FontWeight="Bold" Foreground="#0F172A" />
                                <TextBlock Text="单条确认无误后可立即上传，也可以对当前批次做顺序批量上传。"
                                           Margin="0,2,0,8"
                                           FontSize="12"
                                           Foreground="#64748B"
                                           TextWrapping="Wrap" />
                                <WrapPanel ItemHeight="30">
                                    <Button x:Name="BtnSubmitCurrent" Content="上传当前订单" Width="130" Style="{StaticResource PrimaryActionButtonStyle}" Click="BtnSubmitCurrent_Click" />
                                    <Button x:Name="BtnSubmitAll" Content="批量上传待审订单" Width="160" Style="{StaticResource SecondaryActionButtonStyle}" Click="BtnSubmitAll_Click" />
                                </WrapPanel>
                                <TextBlock x:Name="TxtStatus"
                                           Margin="0,4,0,0"
                                           FontSize="12"
                                           Foreground="#334155"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.7*" />
                            <ColumnDefinition Width="1.25*" />
                            <ColumnDefinition Width="3.35*" />
                        </Grid.ColumnDefinitions>

                        <GroupBox Grid.Column="0" Header="订单文本源" Style="{StaticResource SectionGroupBoxStyle}">
                            <DockPanel Margin="10">
                                <TextBlock DockPanel.Dock="Top"
                                           Text="支持一次粘贴多段文本。解析后会自动拆分成多条订单草稿。"
                                           Margin="0,0,0,8"
                                           Foreground="#64748B"
                                           TextWrapping="Wrap" />
                                <TextBox x:Name="TxtInput"
                                         AcceptsReturn="True"
                                         AcceptsTab="True"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         TextWrapping="Wrap"
                                         FontFamily="Consolas"
                                         FontSize="14" />
                            </DockPanel>
                        </GroupBox>
                        
                        <GroupBox Grid.Column="1" Header="订单队列" Style="{StaticResource SectionGroupBoxStyle}">
                            <DockPanel Margin="10">
                                <TextBlock DockPanel.Dock="Top"
                                           Text="按顺序处理草稿。上传成功或跳过后，系统会自动切换到下一条。"
                                           Margin="0,0,0,8"
                                           Foreground="#64748B"
                                           TextWrapping="Wrap" />
                                <DataGrid x:Name="GridDraftOrders"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          SelectionChanged="GridDraftOrders_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="订单号" Binding="{Binding OrderNumber}" Width="165" />
                                        <DataGridTextColumn Header="收件人" Binding="{Binding ReceiverName}" Width="90" />
                                        <DataGridTextColumn Header="手机号" Binding="{Binding ReceiverMobile}" Width="110" />
                                        <DataGridTextColumn Header="商品概要" Binding="{Binding GoodsSummary}" Width="*" />
                                        <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="90" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </GroupBox>

                        <GroupBox Grid.Column="2" Header="订单草稿编辑" Margin="0,0,0,8">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Background="#EFF6FF"
                                        BorderBrush="#BFDBFE"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12"
                                        Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="当前选中订单摘要" FontWeight="Bold" Foreground="#1E3A8A" />
                                        <TextBlock x:Name="TxtDraftEditorSummary"
                                                   Margin="0,6,0,0"
                                                   Foreground="#334155"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1"
                                        Background="White"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12"
                                        Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="220" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="收件人 *" Margin="0,0,0,4" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="收件手机号 *" Margin="0,0,0,4" />
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="业务员账号" Margin="0,0,0,4" />

                                        <TextBox x:Name="TxtDraftReceiverName" Grid.Row="1" Grid.Column="0" Margin="0,0,10,10" Height="30" />
                                        <TextBox x:Name="TxtDraftReceiverMobile" Grid.Row="1" Grid.Column="1" Margin="0,0,10,10" Height="30" />
                                        <ComboBox x:Name="CmbDraftOperator"
                                                  Grid.Row="1"
                                                  Grid.Column="2"
                                                  Height="30"
                                                  SelectionChanged="CmbDraftOperator_SelectionChanged"
                                                  DisplayMemberPath="DisplayName" />

                                        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Text="详细地址 *" Margin="0,0,0,4" />
                                        <TextBlock Grid.Row="2" Grid.Column="2" Text="附加信息" Margin="0,0,0,4" />

                                        <TextBox x:Name="TxtDraftReceiverAddress"
                                                 Grid.Row="3"
                                                 Grid.Column="0"
                                                 Grid.ColumnSpan="2"
                                                 Margin="0,0,10,0"
                                                 Height="30" />

                                        <StackPanel Grid.Row="3" Grid.Column="2">
                                            <CheckBox x:Name="ChkDraftHasGift"
                                                      Content="是否有赠品"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,0,8" />
                                            <TextBox x:Name="TxtDraftRemark"
                                                     Height="30"
                                                     ToolTip="备注（选填）" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <DockPanel Grid.Row="2">
                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="商品集合（必填：商品编码 / 数量）" FontWeight="Bold" VerticalAlignment="Center" />
                                        <Button x:Name="BtnAddItem" Content="+ 添加商品" Width="100" Height="28" Margin="12,0,8,0" Click="BtnAddItem_Click" />
                                        <Button x:Name="BtnRemoveItem" Content="删除选中商品" Width="110" Height="28" Click="BtnRemoveItem_Click" />
                                    </StackPanel>
                                    <DataGrid x:Name="GridDraftItems"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              SelectionMode="Single"
                                              SelectionChanged="GridDraftItems_SelectionChanged"
                                              CellEditEnding="GridDraftItems_CellEditEnding">
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="商品编码 *" Width="2.25*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding ProductCode}" VerticalAlignment="Center" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                                <DataGridTemplateColumn.CellEditingTemplate>
                                                    <DataTemplate>
                                                        <ComboBox ItemsSource="{Binding ProductCodeOptions}"
                                                                  SelectedValue="{Binding ProductCode, UpdateSourceTrigger=PropertyChanged}"
                                                                  SelectedValuePath="ProductCode"
                                                                  DisplayMemberPath="DisplayText"
                                                                  IsEditable="True"
                                                                  IsTextSearchEnabled="False"
                                                                  StaysOpenOnEdit="True"
                                                                  Loaded="ProductCodeComboBox_Loaded"
                                                                  DropDownOpened="ProductCodeComboBox_DropDownOpened"
                                                                  PreviewKeyUp="ProductCodeComboBox_PreviewKeyUp"
                                                                  SelectionChanged="ProductCodeComboBox_SelectionChanged"
                                                                  LostKeyboardFocus="ProductCodeComboBox_LostKeyboardFocus" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellEditingTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="数量 *" Binding="{Binding QuantityText, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                                            <DataGridTextColumn Header="备注" Binding="{Binding Remark, UpdateSourceTrigger=PropertyChanged}" Width="1.2*" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </Grid>
                        </GroupBox>
                    </Grid>

                    <GroupBox Grid.Row="3" Header="校验 / 上传响应 / 原始记录">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="1.3*" />
                                <ColumnDefinition Width="1.25*" />
                            </Grid.ColumnDefinitions>

                            <GroupBox Grid.Column="0" Header="校验结果">
                                <TextBox x:Name="TxtValidationOutput"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         TextWrapping="Wrap"
                                         FontFamily="Consolas" />
                            </GroupBox>

                            <GroupBox Grid.Column="1" Header="上传响应" Margin="10,0">
                                <TextBox x:Name="TxtUploadOutput"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         TextWrapping="Wrap"
                                         FontFamily="Consolas" />
                            </GroupBox>

                            <GroupBox Grid.Column="2" Header="当前订单原文">
                                <TextBox x:Name="TxtCurrentRawOrder"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         TextWrapping="Wrap"
                                         FontFamily="Consolas" />
                            </GroupBox>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>
            
            <TabItem Header="设置中心">
                <DockPanel Margin="0,6,0,0">
                    <Border DockPanel.Dock="Top"
                            Background="White"
                            CornerRadius="14"
                            Padding="12"
                            Margin="0,0,0,10"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1">
                        <WrapPanel>
                            <Button x:Name="BtnSaveSettings" Content="保存设置" Width="100" Height="34" Margin="0,0,8,8" Click="BtnSaveSettings_Click" />
                            <Button x:Name="BtnImportSettings" Content="导入设置" Width="100" Height="34" Margin="0,0,8,8" Click="BtnImportSettings_Click" />
                            <Button x:Name="BtnExportSettings" Content="导出设置" Width="100" Height="34" Margin="0,0,8,8" Click="BtnExportSettings_Click" />
                            <Button x:Name="BtnAddSettingsRow" Content="新增当前表行" Width="120" Height="34" Margin="0,0,8,8" Click="BtnAddSettingsRow_Click" />
                            <Button x:Name="BtnRemoveSettingsRow" Content="删除当前表行" Width="120" Height="34" Margin="0,0,8,8" Click="BtnRemoveSettingsRow_Click" />
                            <TextBlock x:Name="TxtSettingsStatus" Margin="10,8,0,0" Foreground="#334155" TextWrapping="Wrap" />
                        </WrapPanel>
                    </Border>

                    <TabControl x:Name="SettingsTabs">
                        <TabItem Header="周期列表">
                            <DataGrid x:Name="GridWearPeriods" AutoGenerateColumns="False" CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="标准周期" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="周期对照表">
                            <DataGrid x:Name="GridWearMappings" AutoGenerateColumns="False" CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="文本别名" Binding="{Binding Alias, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                    <DataGridComboBoxColumn x:Name="ColSettingsWearMapping"
                                                            Header="对应周期"
                                                            Width="200"
                                                            SelectedValueBinding="{Binding WearPeriod, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectedValuePath="Value"
                                                            DisplayMemberPath="Value" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="商品编码列表">
                            <DataGrid x:Name="GridProductCatalog" AutoGenerateColumns="False" CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="商品编码" Binding="{Binding ProductCode, UpdateSourceTrigger=PropertyChanged}" Width="160" />
                                    <DataGridTextColumn Header="商品名称" Binding="{Binding ProductName, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="编码对照表">
                            <DataGrid x:Name="GridProductMappings" AutoGenerateColumns="False" CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="文本别名" Binding="{Binding Alias, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                    <DataGridTextColumn Header="商品编码" Binding="{Binding ProductCode, UpdateSourceTrigger=PropertyChanged}" Width="180" />
                                    <DataGridTextColumn Header="备注" Binding="{Binding Note, UpdateSourceTrigger=PropertyChanged}" Width="220" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="账号 ERP 映射">
                            <DataGrid x:Name="GridUserAccounts" AutoGenerateColumns="False" CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="登录账号" Binding="{Binding LoginName, UpdateSourceTrigger=PropertyChanged}" Width="180" />
                                    <DataGridTextColumn Header="显示名" Binding="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" Width="180" />
                                    <DataGridTextColumn Header="ERPID" Binding="{Binding ErpId, UpdateSourceTrigger=PropertyChanged}" Width="180" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="接口配置">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <Grid Margin="20">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="接口地址" Margin="0,0,0,6" />
                                    <TextBox x:Name="TxtUploadApiUrl" Grid.Row="1" Height="30" Margin="0,0,0,12" />
                                    <TextBlock Grid.Row="2" Text="AppKey / Secret" Margin="0,0,0,6" />
                                    <Grid Grid.Row="3" Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="TxtUploadAppKey" Grid.Column="0" Margin="0,0,8,0" Height="30" />
                                        <TextBox x:Name="TxtUploadSecret" Grid.Column="1" Height="30" />
                                    </Grid>
                                    <TextBlock Grid.Row="4" Text="扩展字段名（留空则不传）" Margin="0,0,0,6" />
                                    <Grid Grid.Row="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="TxtOperatorFieldName" Grid.Column="0" Margin="0,0,8,0" Height="30" ToolTip="业务员 ERPID 字段名" />
                                        <TextBox x:Name="TxtGiftFieldName" Grid.Column="1" Margin="0,0,8,0" Height="30" ToolTip="赠品标记字段名" />
                                        <TextBox x:Name="TxtItemWearPeriodFieldName" Grid.Column="2" Height="30" ToolTip="商品周期字段名" />
                                    </Grid>
                                </Grid>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </DockPanel>
            </TabItem>

            <TabItem Header="历史记录">
                <Grid Margin="0,6,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="250" />
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="GridHistory"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              SelectionChanged="GridHistory_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="时间" Binding="{Binding Timestamp}" Width="160" />
                            <DataGridTextColumn Header="动作" Binding="{Binding ActionType}" Width="100" />
                            <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="100" />
                            <DataGridTextColumn Header="收件人" Binding="{Binding ReceiverName}" Width="100" />
                            <DataGridTextColumn Header="手机号" Binding="{Binding ReceiverMobile}" Width="110" />
                            <DataGridTextColumn Header="商品概要" Binding="{Binding GoodsSummary}" Width="*" />
                            <DataGridTextColumn Header="业务员" Binding="{Binding OperatorLoginName}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="1.15*" />
                            <ColumnDefinition Width="1.3*" />
                        </Grid.ColumnDefinitions>
                        <GroupBox Grid.Column="0" Header="原始文本">
                            <TextBox x:Name="TxtHistoryRaw"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     FontFamily="Consolas" />
                        </GroupBox>
                        <GroupBox Grid.Column="1" Header="录入快照" Margin="10,0,0,0">
                            <TextBox x:Name="TxtHistorySnapshot"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     FontFamily="Consolas" />
                        </GroupBox>
                        <GroupBox Grid.Column="2" Header="接口响应 / 处理说明" Margin="10,0,0,0">
                            <TextBox x:Name="TxtHistoryResponse"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     FontFamily="Consolas" />
                        </GroupBox>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
