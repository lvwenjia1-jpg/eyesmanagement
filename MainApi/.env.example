MAINAPI_PORT=8080
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://0.0.0.0:8080
TZ=Asia/Shanghai
UseHttpsRedirection=false

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=mainapi
MYSQL_USER=mainapi
MYSQL_PASSWORD=1234
MYSQL_ROOT_PASSWORD=1234

ConnectionStrings__MainDb=Server=mysql;Port=3306;Database=mainapi;User ID=mainapi;Password=1234;SslMode=None;AllowPublicKeyRetrieval=True;CharSet=utf8mb4;
Jwt__Issuer=MainApi
Jwt__Audience=MainApi.Clients
Jwt__SigningKey=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
Jwt__ExpiresMinutes=480
BootstrapAdmin__LoginName=admin
BootstrapAdmin__Password=CHANGE_THIS_PASSWORD
BootstrapAdmin__ErpId=ERP001
BootstrapAdmin__Role=admin
BootstrapAdmin__MachineCode=DEMO-PC-001
BootstrapAdmin__MachineDescription=Docker Server
DashboardSeed__Enabled=true
DashboardSeed__ResetExistingData=false
DashboardSeed__BusinessGroupCount=6
DashboardSeed__OrdersPerGroup=12
