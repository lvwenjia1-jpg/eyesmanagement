<Window x:Class="MachineCodeTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="机器码获取工具"
        Width="760"
        Height="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#EEF3F8">
    <Grid Margin="28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.8*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="1"
                Margin="18,0,0,0"
                CornerRadius="24"
                Background="White"
                BorderBrush="#D6E2EE"
                BorderThickness="1">
            <Grid Margin="26">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="当前机器码"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#0F172A" />
                <TextBlock Grid.Row="1"
                           Margin="0,8,0,0"
                           Text="点击复制按钮即可复制到剪贴板。"
                           Foreground="#64748B"
                           FontSize="13" />

                <Border Grid.Row="2"
                        Margin="0,22,0,22"
                        Padding="18"
                        CornerRadius="18"
                        Background="#F8FBFF"
                        BorderBrush="#D7E6F5"
                        BorderThickness="1">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="机器码"
                                   FontSize="12"
                                   Foreground="#64748B" />
                        <TextBox x:Name="TxtMachineCode"
                                 Margin="0,10,0,0"
                                 Height="44"
                                 FontSize="18"
                                 FontWeight="SemiBold"
                                 BorderBrush="#B8C9DA"
                                 IsReadOnly="True"
                                 TextAlignment="Center"
                                 Background="White" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnRefresh"
                            Content="刷新"
                            Width="96"
                            Height="40"
                            Margin="0,0,12,0"
                            Click="BtnRefresh_Click"
                            Background="#E2E8F0"
                            BorderBrush="#CBD5E1"
                            Foreground="#0F172A" />
                    <Button x:Name="BtnCopy"
                            Content="复制机器码"
                            Width="124"
                            Height="40"
                            Click="BtnCopy_Click"
                            Background="#2563EB"
                            BorderBrush="#2563EB"
                            Foreground="White" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
